{
  "version": 2,
  "builds": [
    {
      "src": "vault-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "vault-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "vault-backend/server.js" },
    { "src": "/(.*)", "dest": "vault-dashboard/$1" }
  ]
}
